# =============================================================================
# infra/jenkins.env.example
#
# Copy to infra/jenkins.env, fill in your values, then run:
#     source infra/jenkins.env && bash infra/jenkins-setup.sh
#
# DO NOT commit jenkins.env — it contains secrets.
# jenkins.env is listed in .gitignore.
# =============================================================================

# ── Jenkins ───────────────────────────────────────────────────────────────────
export JENKINS_URL="http://192.168.100.151:8080"
export JENKINS_USER="your-jenkins-username"
export JENKINS_TOKEN="your-jenkins-api-token"

# ── Gitea ─────────────────────────────────────────────────────────────────────
# Base URL of your Gitea instance (no trailing slash)
export GITEA_URL="http://192.168.100.X:3000"
# repo path as it appears in the URL: username/repo-name
export GITEA_REPO="your-username/pixxel"
# Gitea user Jenkins will use to clone the repo (read-only access is enough)
export GITEA_USER="your-gitea-username"
# Gitea personal access token (Settings → Applications → Generate Token)
export GITEA_TOKEN="your-gitea-token"

# ── Docker host ───────────────────────────────────────────────────────────────
export DOCKER_HOST_IP="192.168.100.X"
export DEPLOY_USER="deploy"           # user on Docker host Jenkins SSH's in as
export DEPLOY_DIR="/opt/pixxel"       # where code is placed on the host

# ── SSH key ───────────────────────────────────────────────────────────────────
# Path to the private key Jenkins uses to SSH into the Docker host.
# If the file doesn't exist, the script will generate a new key pair here.
export SSH_KEY_FILE="$HOME/.ssh/pixxel_jenkins_deploy"

# ── App secrets (go into .env.production on the Docker host) ──────────────────
export DB_HOST="192.168.100.X"        # DB host reachable FROM the Docker host
export DB_PORT="3306"
export DB_USER="pixxel"
export DB_PASSWORD="your-db-password"
export DB_NAME="pixxel_prod"

# Generate with: openssl rand -base64 32
export NEXTAUTH_SECRET="your-random-32-char-secret"
# Public URL users hit in the browser
export NEXTAUTH_URL="http://192.168.100.X:3000"

# ── Pipeline options (optional — defaults shown) ──────────────────────────────
export JOB_NAME="pixxel"
# Leave blank to auto-generate a random token (printed at end of setup)
export WEBHOOK_TOKEN=""
